# Permitir manifest.json para instalacion PWA
<Files "manifest.json">
    Require all granted
</Files>

# Bloquear config.php
<Files "config.php">
    Require all denied
</Files>

# Bloquear ficheros de datos JSON (data-*.json)
<FilesMatch "^data.*\.json$">
    Require all denied
</FilesMatch>

# Bloquear acceso al directorio semanas
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteRule ^semanas/ - [F,L]
</IfModule>

# Bloquear acceso a .htaccess
<Files .htaccess>
    Require all denied
</Files>
